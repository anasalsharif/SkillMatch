{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "your-firebase-project-id",
          "appId": "YOUR_ANDROID_FIREBASE_APP_ID",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
            "projectId": "your-firebase-project-id",
          "configurations": {
            "android": "YOUR_ANDROID_FIREBASE_APP_ID",
            "ios": "YOUR_IOS_FIREBASE_APP_ID",
            "macos": "YOUR_MACOS_FIREBASE_APP_ID",
            "web": "YOUR_WEB_FIREBASE_APP_ID",
            "windows": "YOUR_WINDOWS_FIREBASE_APP_ID"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "./build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
