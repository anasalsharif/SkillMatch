PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/skillmatch?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_BASE_URL=http://localhost:5000

EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password

GOOGLE_APPLICATION_CREDENTIALS=C:\absolute\path\to\firebase-service-account.json
GCS_KEY_FILE=C:\absolute\path\to\google-cloud-storage-key.json
GCS_BUCKET=your-gcs-bucket-name

# AI provider. The app uses the OpenAI SDK and supports OpenAI-compatible APIs.
# Option A: OpenAI / GitHub Models / OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://models.github.ai/inference
OPENAI_MODEL=gpt-4o

# Option B: Gemini through Google's OpenAI-compatible endpoint
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Local demo workaround only if Node cannot verify Google/GitHub TLS certificates.
# Remove or leave unset in production.
NODE_TLS_REJECT_UNAUTHORIZED=

ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_ACCOUNT_ID=your-zoom-account-id
MAIN_VERIFY_EMAIL_URL=http://localhost:5000/api/auth/verify-email/
